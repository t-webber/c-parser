static atomic_bool global_early_exit = 0;

typedef struct {
        const unsigned int *words;
        size_t len;
        size_t start_idx;
        size_t end_idx;
        int local_min;
} ThreadArgs;

static void *worker_thread(void *arg) {
        ThreadArgs *args = (ThreadArgs *)arg;
        args->local_min = 32;

        for (size_t i = args->start_idx; i < args->end_idx; i++) {
                if (global_early_exit) break;

                unsigned int query = args->words[i];
                __m256i q_vec = _mm256_set1_epi32(query);

                size_t j = i + 1;
                if (args->len >= 8) {
                        for (; j <= args->len - 8; j += 8) {
                                __m256i d_vec = _mm256_loadu_si256(
                                    (const __m256i *)&args->words[j]);
                                __m256i xor_res
                                    = _mm256_xor_si256(q_vec, d_vec);

                                uint32_t diffs[8];
                                _mm256_storeu_si256((__m256i *)diffs, xor_res);

                                for (int k = 0; k < 8; k++) {
                                        int d = __builtin_popcount(diffs[k]);
                                        if (d && d < args->local_min) {
                                                args->local_min = d;
                                                if (args->local_min == 1) {
                                                        global_early_exit = 1;
                                                        return 
                                                              ((void *)0)
                                                                  ;
                                                }
                                        }
                                }
                        }
                }

                for (; j < args->len; j++) {
                        if (i == j) continue;
                        int d = __builtin_popcount(query ^ args->words[j]);
                        if (d && d < args->local_min) {
                                args->local_min = d;
                                if (args->local_min == 1) {
                                        global_early_exit = 1;
                                        return 
                                              ((void *)0)
                                                  ;
                                }
                        }
                }
        }
        return 
              ((void *)0)
                  ;
}

static int hamming_pthreads_avx2(const unsigned int words[], const size_t len) {
        if (len < 2) return 0;

        pthread_t threads[8];
        ThreadArgs thread_args[8];
        global_early_exit = 0;

        size_t chunk_size = len / 8;

        for (size_t t = 0; t < 8; t++) {
                thread_args[t].words = words;
                thread_args[t].len = len;
                thread_args[t].start_idx = t * chunk_size;

                thread_args[t].end_idx
                    = (t == 8 - 1) ? len : (t + 1) * chunk_size;
                thread_args[t].local_min = 32;

                pthread_create(&threads[t],
                               
                              ((void *)0)
                                  ,
                               worker_thread,
                               &thread_args[t]);
        }

        int absolute_min = 32;
        for (int t = 0; t < 8; t++) {
                pthread_join(threads[t], 
                                        ((void *)0)
                                            );
                if (thread_args[t].local_min < absolute_min) {
                        absolute_min = thread_args[t].local_min;
                }
        }

        return absolute_min;
}






static int hamming_simd_avx2(const unsigned int words[], const size_t len) {
        if (len < 2) return 0;
        int global_min = 32;

        for (size_t i = 0; i < len; i++) {
                unsigned int query = words[i];
                __m256i q_vec = _mm256_set1_epi32(query);

                size_t j = i + 1;
                if (len >= 8) {
                        for (; j <= len - 8; j += 8) {
                                __m256i d_vec
                                    = _mm256_loadu_si256((__m256i *)&words[j]);
                                __m256i xor_res
                                    = _mm256_xor_si256(q_vec, d_vec);

                                uint32_t diffs[8];
                                _mm256_storeu_si256((__m256i *)diffs, xor_res);

                                for (int k = 0; k < 8; k++) {
                                        int d = __builtin_popcount(diffs[k]);
                                        if (d && d < global_min) {
                                                global_min = d;
                                                if (global_min == 1) return 1;
                                        }
                                }
                        }
                }

                for (; j < len; j++) {
                        if (i == j) continue;
                        int d = __builtin_popcount(query ^ words[j]);
                        if (d < global_min) global_min = d;
                }
        }
        return global_min;
}



static int hamming_naive(const unsigned int words[], const size_t len_words) {
        if (len_words < 2) return 0;
        int min_distance = 32;
        for (size_t i = 0; i < len_words; i++) {
                for (size_t j = i + 1; j < len_words; j++) {
                        int distance = __builtin_popcount(words[i] ^ words[j]);
                        if (distance == 1) return 1;
                        if (distance && distance < min_distance) {
                                min_distance = distance;
                        }
                }
        }
        return min_distance;
}



typedef struct TrieNode {
        struct TrieNode *children[2];
        bool exists;
} TrieNode;

static unsigned min(unsigned a, unsigned b) {
        unsigned cmin = (a > b ? b : a);
        return cmin ? cmin : (a + b);
}

static unsigned rqa(const TrieNode *const node,
                    const unsigned word,
                    unsigned cmin,
                    const unsigned dist) {
        if (!node) return cmin;
        if (dist >= cmin) return cmin;

        if (node->exists) cmin = min(cmin, dist);
        if (cmin == 1) return 1;

        int bit = word & 1;
        cmin = min(cmin,
                   rqa(node->children[0], word >> 1, cmin, dist + (bit != 0)));
        if (cmin == 1) return 1;
        cmin = min(cmin,
                   rqa(node->children[1], word >> 1, cmin, dist + (bit != 1)));
        if (cmin == 1) return 1;
        return cmin;
}

static void trie_insert(TrieNode *root, unsigned int word) {
        TrieNode *curr = root;
        for (int i = 0; i < 32; ++i) {
                unsigned bit = word & 1;
                word >>= 1;
                if (!curr->children[bit]) {
                        curr->children[bit]
                            = (TrieNode *)calloc(1, sizeof(TrieNode));
                }
                curr = curr->children[bit];
        }
        curr->exists = true;
}

static void trie_free(TrieNode *node) {
        if (!node) return;
        trie_free(node->children[0]);
        trie_free(node->children[1]);
        free(node);
}

static int hamming_trie(const unsigned int words[], const size_t len_words) {
        if (len_words < 2) return 0;

        TrieNode *root = (TrieNode *)calloc(1, sizeof(TrieNode));
        for (size_t i = 0; i < len_words; i++) { trie_insert(root, words[i]); }

        unsigned min_dist = 32;
        for (size_t i = 0; i < len_words; i++) {
                unsigned local_min = rqa(root, words[i], min_dist, 0);
                if (local_min < min_dist) {
                        min_dist = local_min;
                        if (min_dist == 1) break;
                }
        }

        trie_free(root);
        return (int)min_dist;
}






typedef struct {
        unsigned *data;
        size_t size;
        size_t capacity;
} bucket;

typedef bucket bucket_tables[4][256];

static void append_mih(bucket *const b, const unsigned word) {
        if (b->size >= b->capacity) {
                b->capacity = b->capacity == 0 ? 8 : b->capacity * 2;
                b->data = realloc(b->data, b->capacity * sizeof(unsigned));
        }
        b->data[b->size++] = word;
}

static void mih_word_distance(const unsigned word,
                              int *const min,
                              const bucket_tables tables) {

        for (int t = 0; t < 4; t++) {
                uint8_t target_chunk = (word >> (t * 8)) & 0xFF;

                for (unsigned bucket_idx = 0; bucket_idx < 256;
                     ++bucket_idx) {
                        int chunk_dist
                            = __builtin_popcount(target_chunk ^ bucket_idx);

                        if (chunk_dist * 4 >= *min) continue;

                        const bucket *const b = &tables[t][bucket_idx];
                        for (size_t j = 0; j < b->size; j++) {
                                unsigned other = b->data[j];
                                if (other == word) continue;

                                int dist = __builtin_popcount(word ^ other);
                                if (dist < *min) {
                                        *min = dist;
                                        if (dist == 1) return;
                                }
                        }
                }
        }
}

static int hamming_mih(const unsigned int words[], const size_t len_words) {
        if (len_words < 2) return 0;

        bucket_tables tables;
        memset(tables, 0, sizeof(tables));

        for (size_t i = 0; i < len_words; i++) {
                unsigned int w = words[i];
                append_mih(&tables[0][(w >> 0) & 0xFF], w);
                append_mih(&tables[1][(w >> 8) & 0xFF], w);
                append_mih(&tables[2][(w >> 16) & 0xFF], w);
                append_mih(&tables[3][(w >> 24) & 0xFF], w);
        }

        int min = 32;

        for (size_t i = 0; i < len_words; i++)
                mih_word_distance(words[i], &min, tables);

        for (int t = 0; t < 4; t++) {
                for (int b = 0; b < 256; b++) free(tables[t][b].data);
        }
        return min;
}



typedef struct BKNode {
        unsigned int word;
        struct BKNode *children[33];
} BKNode;

static void bk_insert(BKNode *root, unsigned int word) {
        BKNode *curr = root;
        while (1) {
                int dist = __builtin_popcount(curr->word ^ word);
                if (dist == 0) return;

                if (!curr->children[dist]) {
                        BKNode *new_node = (BKNode *)calloc(1, sizeof(BKNode));
                        new_node->word = word;
                        curr->children[dist] = new_node;
                        return;
                }
                curr = curr->children[dist];
        }
}

static void bk_search(BKNode *node, unsigned int query, int *current_min) {
        if (!node) return;

        int dist = __builtin_popcount(node->word ^ query);
        if (dist > 0 && dist < *current_min) {
                *current_min = dist;
                if (*current_min == 1) return;
        }

        int low = dist - *current_min;
        int high = dist + *current_min;
        if (low < 0) low = 0;
        if (high > 32) high = 32;

        for (int i = low; i <= high; i++) {
                if (node->children[i]) {
                        bk_search(node->children[i], query, current_min);
                        if (*current_min == 1) return;
                }
        }
}

static void bk_free(BKNode *node) {
        if (!node) return;
        for (int i = 0; i < 32; ++i) bk_free(node->children[i]);
        free(node);
}

static int hamming_bktree(const unsigned int words[], const size_t len_words) {
        if (len_words < 2) return 0;

        BKNode *root = (BKNode *)calloc(1, sizeof(BKNode));
        root->word = words[0];

        for (size_t i = 1; i < len_words; i++) { bk_insert(root, words[i]); }

        int global_min = 32;
        for (size_t i = 0; i < len_words; i++) {
                bk_search(root, words[i], &global_min);
                if (global_min == 1) break;
        }

        bk_free(root);

        return global_min;
}



static unsigned int *generate_random_words(const size_t len,
                                           const unsigned int seed) {
        unsigned int *const words = malloc(sizeof(unsigned int) * len);
        srand(seed);
        for (size_t i = 0; i < len; i++) { words[i] = (unsigned)rand(); }
        return words;
}

typedef int (*func)(const unsigned int[], size_t);

static unsigned long long int time_ns(void) {
        struct timespec start;
        clock_gettime(
                     1
                                    , &start);
        return start.tv_sec * 1e9 + start.tv_nsec;
}

static unsigned long long benchmark(func fn,
                                    const unsigned int words[],
                                    const size_t len,
                                    const size_t iter,
                                    volatile int *const res) {
        unsigned long long start = time_ns();
        for (size_t i = 0; i < iter; i++) { *res = fn(words, len); }
        unsigned long long end = time_ns();

        return (end - start) / 1000000LL;
}

const func FNS[] = {
    hamming_pthreads_avx2,
    hamming_simd_avx2,
    hamming_naive,
    hamming_trie,
    hamming_mih,
    hamming_bktree,
};

const char *const FN_NAMES[] = {
    "hamming_pthreads_avx2",
    "hamming_simd_avx2",
    "hamming_naive",
    "hamming_trie",
    "hamming_mih",
    "hamming_bktree",
};

const size_t FN_LEN = sizeof(FNS) / sizeof(FNS[0]);

static void run_experience(const size_t nb_words,
                           unsigned int *const times,
                           const unsigned int seed,
                           const size_t iter) {
        unsigned int *const words = generate_random_words(nb_words, seed);
        const int expected = hamming_naive(words, nb_words);
        for (size_t fn_id = 0; fn_id < FN_LEN; ++fn_id) {
                volatile int res;
                times[fn_id]
                    += benchmark(FNS[fn_id], words, nb_words, iter, &res);

                if (res != expected) {
                        printf(
                            "\n%s differ on seed %d len %zu: expected %d, got "
                            "%d\n",
                            FN_NAMES[fn_id],
                            seed,
                            nb_words,
                            expected,
                            res);
                        for (size_t i = 0; i < nb_words; ++i)
                                printf("%d : ", words[i]);
                        printf("\n");
                }
        }
        free(words);
}

static void run_benchmarks(const size_t exp_nb,
                           const size_t nb_words,
                           const unsigned int *seeds,
                           const size_t iter) {
        unsigned int *const res = malloc(FN_LEN * sizeof(unsigned int));
        for (size_t exp_id = 0; exp_id < exp_nb; ++exp_id) {
                run_experience(nb_words, res, seeds[exp_id], iter);
        }
        printf("\rBenchmarks for %zu experiences on %zu words:\n",
               exp_nb,
               nb_words);
        for (size_t i = 0; i < FN_LEN; ++i) {
                printf(" %s %-30s %zu ms\n",
                       i + 1 == FN_LEN ? "└" : "│",
                       FN_NAMES[i],
                       res[i] / exp_nb);
                res[i] /= exp_nb;
        }
        free(res);
}

